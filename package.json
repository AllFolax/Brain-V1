{
  "name": "@ruben/brain",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Lightweight markdown-based persistent memory for AI assistants (V1, standalone). Framework-agnostic. Zero runtime devDeps beyond Bun and Node stdlib.",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types.ts",
    "./freebuff": "./src/integrations/freebuff.ts",
    "./freebuff/types": "./src/integrations/freebuff.types.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "check": "bun run typecheck && bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^5.5.4"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "keywords": [
    "memory",
    "markdown",
    "ai",
    "notes",
    "knowledge"
  ],
  "license": "Apache-2.0"
}
